# Copy this file to .env and fill in your values

# Gemini (required — default AI backend)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# Claude (optional — enables Claude model selection in the UI)
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_INPUT_COST_PER_MTK=3.0
CLAUDE_OUTPUT_COST_PER_MTK=15.0

# Auth
JWT_SECRET=generate-a-random-secret-here

# Admin account(s) — comma-separated usernames
ADMIN_USERNAME=yourusername
# ADMIN_USERNAMES=user1,user2

# Acunetix (optional — remove or leave blank to disable)
ACUNETIX_API_KEY=your-acunetix-api-key
ACUNETIX_URL=https://your-acunetix-host:3443/api/v1

# Ngrok (optional — only needed for public tunneling)
NGROK_TOKEN=your-ngrok-token
